# Repository defaults tracked in Git for this generated consumer.
# Keep this file non-sensitive; put passwords/tokens in blueprint/repo.init.secrets.env.
# Auto-loaded by blueprint-init-repo, blueprint-check-placeholders, and infra targets.

BLUEPRINT_REPO_NAME=your-platform-blueprint
BLUEPRINT_GITHUB_ORG=your-github-org
BLUEPRINT_GITHUB_REPO=your-platform-blueprint
BLUEPRINT_DEFAULT_BRANCH=main
BLUEPRINT_DOCS_TITLE="Your Platform Blueprint"
BLUEPRINT_DOCS_TAGLINE="Reusable local+STACKIT platform blueprint"
BLUEPRINT_STACKIT_REGION=eu01
BLUEPRINT_STACKIT_TENANT_SLUG=your-tenant-slug
BLUEPRINT_STACKIT_PLATFORM_SLUG=your-platform-slug
BLUEPRINT_STACKIT_PROJECT_ID=your-stackit-project-id
BLUEPRINT_STACKIT_TFSTATE_BUCKET=your-stackit-tfstate-bucket
BLUEPRINT_STACKIT_TFSTATE_KEY_PREFIX=terraform/state
BLUEPRINT_PROFILE=local-full

# Mandatory Keycloak identity baseline (must be consumer-supplied).
KEYCLOAK_PUBLIC_HOST=auth.example.invalid
KEYCLOAK_ACME_EMAIL=noreply@example.invalid
KEYCLOAK_REALM_IAP=iap
KEYCLOAK_REALM_WORKFLOWS=workflows
KEYCLOAK_REALM_LANGFUSE=langfuse
KEYCLOAK_ISSUER_URL=https://${KEYCLOAK_PUBLIC_HOST}/realms/${KEYCLOAK_REALM_IAP}
STACKIT_WORKFLOWS_OIDC_DISCOVERY_URL=https://${KEYCLOAK_PUBLIC_HOST}/realms/${KEYCLOAK_REALM_WORKFLOWS}/.well-known/openid-configuration
LANGFUSE_OIDC_ISSUER_URL=https://${KEYCLOAK_PUBLIC_HOST}/realms/${KEYCLOAK_REALM_LANGFUSE}

OBSERVABILITY_ENABLED=false
WORKFLOWS_ENABLED=false
LANGFUSE_ENABLED=false
POSTGRES_ENABLED=false
NEO4J_ENABLED=false
OBJECT_STORAGE_ENABLED=false
RABBITMQ_ENABLED=false
DNS_ENABLED=false
PUBLIC_ENDPOINTS_ENABLED=false
SECRETS_MANAGER_ENABLED=false
KMS_ENABLED=false
IDENTITY_AWARE_PROXY_ENABLED=false
APP_CATALOG_SCAFFOLD_ENABLED=false
EVENT_MESSAGING_BASELINE_ENABLED=false
ZERO_DOWNTIME_EVOLUTION_ENABLED=false
TENANT_CONTEXT_PROPAGATION_ENABLED=false

KEYCLOAK_OPTIONAL_MODULE_RECONCILIATION_ENABLED=true
RUNTIME_CREDENTIALS_SOURCE_NAMESPACE=security
RUNTIME_CREDENTIALS_TARGET_NAMESPACE=apps
RUNTIME_CREDENTIALS_ESO_WAIT_TIMEOUT=180
# Reconcile command is always executed; this knob only controls fatal vs warn-on-failure behavior.
RUNTIME_CREDENTIALS_REQUIRED=false

ASYNC_PACT_MESSAGE_CONTRACTS_ENABLED=false
ASYNC_PACT_PRODUCER_VERIFY_CMD=
ASYNC_PACT_CONSUMER_VERIFY_CMD=
ASYNC_PACT_BROKER_PUBLISH_CMD=
ASYNC_PACT_CAN_I_DEPLOY_CMD=
ASYNC_PACT_PRODUCER_ARTIFACT_DIR=artifacts/contracts/async/pact/producer
ASYNC_PACT_CONSUMER_ARTIFACT_DIR=artifacts/contracts/async/pact/consumer
