{
  "title": "Blueprint Test Pyramid Contract",
  "description": "Canonical scope classification and thresholds for repository tests.",
  "thresholds": {
    "unit_min_exclusive": 0.6,
    "integration_max_inclusive": 0.3,
    "e2e_max_inclusive": 0.1
  },
  "classifications": [
    {
      "scope": "unit",
      "patterns": [
        "tests/blueprint/test_contract_stackit_runtime.py",
        "tests/blueprint/test_contract_bootstrap_surface.py",
        "tests/blueprint/test_contract_quality_tooling.py",
        "tests/blueprint/test_contract_init_governance.py",
        "tests/blueprint/test_init_repo_env.py",
        "tests/blueprint/test_upgrade_consumer.py",
        "tests/blueprint/test_resync_consumer_seeds.py",
        "tests/blueprint/test_quality_contracts.py",
        "tests/blueprint/test_optional_runtime_contract_validation.py",
        "tests/docs/test_docs_lint.py",
        "tests/infra/test_runtime_credentials_eso.py",
        "tests/infra/test_stackit_layers.py",
        "tests/infra/test_tooling_contracts.py",
        "tests/infra/test_workload_health_check.py"
      ]
    },
    {
      "scope": "integration",
      "patterns": [
        "tests/docs/test_docs_generation.py",
        "tests/infra/test_async_message_contracts.py",
        "tests/infra/test_core_runtime_bootstrap.py",
        "tests/infra/test_optional_modules.py",
        "tests/infra/test_smoke_status_diagnostics.py"
      ]
    },
    {
      "scope": "e2e",
      "patterns": [
        "tests/e2e/test_vertical_slice.py"
      ]
    }
  ]
}
