{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Blueprint Upgrade Apply Report",
  "type": "object",
  "required": [
    "repo_root",
    "source",
    "upgrade_ref",
    "resolved_upgrade_commit",
    "baseline_ref",
    "apply_enabled",
    "allow_delete",
    "status",
    "results",
    "required_manual_actions",
    "summary"
  ],
  "properties": {
    "repo_root": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "upgrade_ref": {
      "type": "string"
    },
    "resolved_upgrade_commit": {
      "type": "string"
    },
    "baseline_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "apply_enabled": {
      "type": "boolean"
    },
    "allow_delete": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure"
      ]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "planned_action",
          "planned_operation",
          "result",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "planned_action": {
            "type": "string"
          },
          "planned_operation": {
            "type": "string"
          },
          "result": {
            "type": "string",
            "enum": [
              "planned-only",
              "skipped",
              "applied",
              "deleted",
              "merged",
              "conflict"
            ]
          },
          "reason": {
            "type": "string"
          },
          "conflict_artifact": {
            "type": "string"
          },
          "semantic": {
            "type": ["object", "null"],
            "properties": {
              "kind": {
                "type": "string",
                "enum": [
                  "function-added",
                  "function-removed",
                  "variable-changed",
                  "source-directive-added",
                  "structural-change"
                ]
              },
              "description": {
                "type": "string"
              },
              "verification_hints": {
                "type": "array",
                "items": {"type": "string"},
                "minItems": 1
              }
            },
            "required": ["kind", "description", "verification_hints"]
          }
        }
      }
    },
    "required_manual_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dependency_path",
          "dependency_of",
          "reason",
          "required_follow_up_commands"
        ],
        "properties": {
          "dependency_path": {
            "type": "string"
          },
          "dependency_of": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "required_follow_up_commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "applied_count",
        "required_manual_action_count"
      ],
      "properties": {
        "total": {
          "type": "integer"
        },
        "applied_count": {
          "type": "integer"
        },
        "required_manual_action_count": {
          "type": "integer"
        }
      }
    },
    "merge_markers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
