# DEPRECATED generated compatibility artifact.
# apps/descriptor.yaml is the canonical consumer-owned app metadata source.
# This file is regenerated from apps/descriptor.yaml on every `make apps-bootstrap`.
# It will be removed after the two minor release migration window
# (trigger: after: consumer-app-descriptor-adoption — see AGENTS.backlog.md).
# Do not edit by hand — edit apps/descriptor.yaml instead.
schemaVersion: v1
appVersionContract:
  appVersionEnv: APP_VERSION
  appBuildIdEnv: APP_BUILD_ID
  appReleaseEnv: APP_RELEASE
runtimePinnedVersions:
  python: ${PYTHON_RUNTIME_BASE_IMAGE_VERSION}
  node: ${NODE_RUNTIME_BASE_IMAGE_VERSION}
  nginx: ${NGINX_RUNTIME_BASE_IMAGE_VERSION}
frameworkPinnedVersions:
  fastapi: ${FASTAPI_VERSION}
  pydantic: ${PYDANTIC_VERSION}
  vue: ${VUE_VERSION}
  vue_router: ${VUE_ROUTER_VERSION}
  pinia: ${PINIA_VERSION}
deliveryTopology:
  workloads:
${DELIVERY_WORKLOADS_BLOCK}
runtimeDeliveryContract:
  gitopsEnabled: ${APP_RUNTIME_GITOPS_ENABLED}
  mode: k8s-manifests
  environmentPathPattern: infra/gitops/platform/environments/<env>
  manifestsRoot: infra/gitops/platform/base/apps
  gitopsWorkloads:
${GITOPS_WORKLOADS_BLOCK}
observabilityRuntimeContract:
  enabled: ${OBSERVABILITY_ENABLED}
  otel:
    endpoint: "${OTEL_EXPORTER_OTLP_ENDPOINT}"
    protocol: "${OTEL_PROTOCOL}"
    tracesEnabled: ${OTEL_TRACES_ENABLED}
    metricsEnabled: ${OTEL_METRICS_ENABLED}
    logsEnabled: ${OTEL_LOGS_ENABLED}
  faro:
    enabled: ${FARO_ENABLED}
    collectPath: "${FARO_COLLECT_PATH}"
