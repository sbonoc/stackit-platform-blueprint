apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: platform-keycloak-{{ENV}}
  namespace: argocd
  labels:
    app.kubernetes.io/part-of: platform-blueprint
    app.kubernetes.io/component: authn-authz
    app.kubernetes.io/name: keycloak
    app.kubernetes.io/environment: {{ENV}}
spec:
  project: platform-{{ENV}}
  destination:
    server: https://kubernetes.default.svc
    namespace: {{KEYCLOAK_NAMESPACE}}
  source:
    repoURL: https://codecentric.github.io/helm-charts
    chart: keycloakx
    targetRevision: {{KEYCLOAK_HELM_CHART_VERSION}}
    helm:
      releaseName: {{KEYCLOAK_HELM_RELEASE}}
      values: |
        image:
          repository: quay.io/keycloak/keycloak
          tag: "{{KEYCLOAK_IMAGE_TAG}}"
          pullPolicy: IfNotPresent
        args:
          - start
        proxy:
          enabled: true
          mode: xforwarded
          http:
            enabled: true
        http:
          relativePath: "/"
        service:
          type: ClusterIP
          httpPort: 80
        extraEnv: |
          - name: KC_DB_URL_HOST
            valueFrom:
              secretKeyRef:
                name: keycloak-runtime-credentials
                key: KEYCLOAK_DATABASE_HOST
          - name: KC_DB_URL_PORT
            valueFrom:
              secretKeyRef:
                name: keycloak-runtime-credentials
                key: KEYCLOAK_DATABASE_PORT
          - name: KC_DB_URL_DATABASE
            valueFrom:
              secretKeyRef:
                name: keycloak-runtime-credentials
                key: KEYCLOAK_DATABASE_NAME
          - name: KC_DB_USERNAME
            valueFrom:
              secretKeyRef:
                name: keycloak-runtime-credentials
                key: KEYCLOAK_DATABASE_USERNAME
          - name: KC_BOOTSTRAP_ADMIN_USERNAME
            value: "{{KEYCLOAK_ADMIN_USERNAME}}"
          - name: KC_BOOTSTRAP_ADMIN_PASSWORD
            valueFrom:
              secretKeyRef:
                name: keycloak-runtime-credentials
                key: KEYCLOAK_ADMIN_PASSWORD
          - name: KC_HOSTNAME
            value: "{{KEYCLOAK_PUBLIC_HOST}}"
          - name: KC_PROXY_HEADERS
            value: "xforwarded"
          - name: KC_HOSTNAME_STRICT
            value: "false"
        database:
          vendor: postgres
          hostname: ""
          port: ""
          database: ""
          username: ""
          existingSecret: keycloak-runtime-credentials
          existingSecretKey: KEYCLOAK_DATABASE_PASSWORD
{{KEYCLOAK_EXTRA_MANIFESTS_BLOCK}}
  syncPolicy:
{{KEYCLOAK_SYNC_AUTOMATED_BLOCK}}
    syncOptions:
      - CreateNamespace=true
      - PrunePropagationPolicy=foreground
      - PruneLast=true
