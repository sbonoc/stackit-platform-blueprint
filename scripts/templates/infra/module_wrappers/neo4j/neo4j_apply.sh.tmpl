#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_neo4j_apply"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled neo4j; then
  log_info "NEO4J_ENABLED=false; skipping neo4j apply"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=neo4j action=apply target=infra-neo4j-apply"
state_file="$(
  write_state_file "neo4j_apply" \
    "status=not_implemented" \
    "module=neo4j" \
    "action=apply" \
    "target=infra-neo4j-apply" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=neo4j action=apply target=infra-neo4j-apply"
log_error "copy this skeleton into scripts/bin/infra/neo4j_apply.sh and replace the stub implementation"
log_info "neo4j apply stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
