#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_object_storage_plan"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled object-storage; then
  log_info "OBJECT_STORAGE_ENABLED=false; skipping object-storage plan"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=object-storage action=plan target=infra-object-storage-plan"
state_file="$(
  write_state_file "object-storage_plan" \
    "status=not_implemented" \
    "module=object-storage" \
    "action=plan" \
    "target=infra-object-storage-plan" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=object-storage action=plan target=infra-object-storage-plan"
log_error "copy this skeleton into scripts/bin/infra/object_storage_plan.sh and replace the stub implementation"
log_info "object-storage plan stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
