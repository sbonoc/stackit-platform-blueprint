#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_stackit_workflows_dag_deploy"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled workflows; then
  log_info "WORKFLOWS_ENABLED=false; skipping workflows deploy dags"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=workflows action=deploy_dags target=infra-stackit-workflows-dag-deploy"
state_file="$(
  write_state_file "workflows_deploy_dags" \
    "status=not_implemented" \
    "module=workflows" \
    "action=deploy_dags" \
    "target=infra-stackit-workflows-dag-deploy" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=workflows action=deploy_dags target=infra-stackit-workflows-dag-deploy"
log_error "copy this skeleton into scripts/bin/infra/stackit_workflows_dag_deploy.sh and replace the stub implementation"
log_info "workflows deploy dags stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
