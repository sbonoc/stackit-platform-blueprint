#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_identity_aware_proxy_destroy"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled identity-aware-proxy; then
  log_info "IDENTITY_AWARE_PROXY_ENABLED=false; skipping identity-aware-proxy destroy"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=identity-aware-proxy action=destroy target=infra-identity-aware-proxy-destroy"
state_file="$(
  write_state_file "identity-aware-proxy_destroy" \
    "status=not_implemented" \
    "module=identity-aware-proxy" \
    "action=destroy" \
    "target=infra-identity-aware-proxy-destroy" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=identity-aware-proxy action=destroy target=infra-identity-aware-proxy-destroy"
log_error "copy this skeleton into scripts/bin/infra/identity_aware_proxy_destroy.sh and replace the stub implementation"
log_info "identity-aware-proxy destroy stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
