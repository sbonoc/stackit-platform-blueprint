#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_public_endpoints_destroy"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled public-endpoints; then
  log_info "PUBLIC_ENDPOINTS_ENABLED=false; skipping public-endpoints destroy"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=public-endpoints action=destroy target=infra-public-endpoints-destroy"
state_file="$(
  write_state_file "public-endpoints_destroy" \
    "status=not_implemented" \
    "module=public-endpoints" \
    "action=destroy" \
    "target=infra-public-endpoints-destroy" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=public-endpoints action=destroy target=infra-public-endpoints-destroy"
log_error "copy this skeleton into scripts/bin/infra/public_endpoints_destroy.sh and replace the stub implementation"
log_info "public-endpoints destroy stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
