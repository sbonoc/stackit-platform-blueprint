#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_rabbitmq_smoke"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled rabbitmq; then
  log_info "RABBITMQ_ENABLED=false; skipping rabbitmq smoke"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=rabbitmq action=smoke target=infra-rabbitmq-smoke"
state_file="$(
  write_state_file "rabbitmq_smoke" \
    "status=not_implemented" \
    "module=rabbitmq" \
    "action=smoke" \
    "target=infra-rabbitmq-smoke" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=rabbitmq action=smoke target=infra-rabbitmq-smoke"
log_error "copy this skeleton into scripts/bin/infra/rabbitmq_smoke.sh and replace the stub implementation"
log_info "rabbitmq smoke stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
