#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"
source "$ROOT_DIR/scripts/lib/shell/bootstrap.sh"
source "$ROOT_DIR/scripts/lib/infra/state.sh"

start_script_metric_trap "infra_observability_apply"

# Generated wrapper skeleton from blueprint/modules/*/module.contract.yaml.
# Copy into scripts/bin/infra/ and replace placeholders with module-specific implementation.

if ! is_module_enabled observability; then
  log_info "OBSERVABILITY_ENABLED=false; skipping observability apply"
  exit 0
fi

set_state_namespace infra

readonly MODULE_WRAPPER_STUB_EXIT_CODE=64

# Explicit stub: template consumers must replace this block with module-specific logic.
log_metric "optional_module_wrapper_stub_invocation" "1" "module=observability action=apply target=infra-observability-apply"
state_file="$(
  write_state_file "observability_apply" \
    "status=not_implemented" \
    "module=observability" \
    "action=apply" \
    "target=infra-observability-apply" \
    "timestamp_utc=$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
)"
log_error "module wrapper not implemented: module=observability action=apply target=infra-observability-apply"
log_error "copy this skeleton into scripts/bin/infra/observability_apply.sh and replace the stub implementation"
log_info "observability apply stub state written to $state_file"
exit "$MODULE_WRAPPER_STUB_EXIT_CODE"
