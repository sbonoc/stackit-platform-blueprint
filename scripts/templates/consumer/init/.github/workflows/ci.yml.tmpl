name: ci

on:
  pull_request:
  push:
    branches:
      - {{DEFAULT_BRANCH}}
  workflow_dispatch:

permissions:
  contents: read

jobs:
  quality-fast:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Prepare shared CI baseline
        uses: ./.github/actions/prepare-blueprint-ci

      - name: Run fast quality gate
        run: |
          make quality-ci-fast

      - name: Run canonical full e2e lane on branch updates
        if: github.event_name != 'pull_request'
        run: |
          make quality-ci-full-e2e

      - name: Run tooling tests
        run: python3 -m pytest -q tests

  quality-strict:
    if: github.event_name != 'pull_request'
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v6

      - name: Prepare shared CI baseline
        uses: ./.github/actions/prepare-blueprint-ci

      - name: Run strict audit gate
        run: |
          make quality-ci-strict
