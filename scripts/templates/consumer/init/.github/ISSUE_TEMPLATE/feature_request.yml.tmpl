name: Project Feature Request
description: Propose an improvement for this generated platform repository.
title: "[feature]: "
labels:
  - enhancement
body:
  - type: textarea
    id: problem
    attributes:
      label: Problem statement
    validations:
      required: true
  - type: textarea
    id: proposal
    attributes:
      label: Proposed change
    validations:
      required: true
  - type: textarea
    id: validation
    attributes:
      label: Validation and rollout notes
      description: Call out any docs, test, or migration impact.
    validations:
      required: true
